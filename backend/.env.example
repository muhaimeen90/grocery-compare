# Application Settings
APP_NAME="Grocery Price Comparison API"
DEBUG=true

# Database - PostgreSQL (use docker-compose.db.yml to start)
DATABASE_URL="postgresql://grocery_user:grocery_password@localhost:5432/grocery_db"

# PostgreSQL Configuration (for docker-compose.db.yml)
POSTGRES_USER=grocery_user
POSTGRES_PASSWORD=grocery_password
POSTGRES_DB=grocery_db

# CORS Origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Scraping Settings
MAX_CONCURRENT_SCRAPES=5
SCRAPE_TIMEOUT=30

PINECONE_API_KEY=